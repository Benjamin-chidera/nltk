   "source": [
    "from nltk.stem import PorterStemmer\n",
    "\n",
    "ps = PorterStemmer()\n",
    "\n",
    "connect_tokens = [\"connecting\", \"connected\", \"connectivity\", \"connects\", \"connection\"]\n",
    "\n",
    "for t in connect_tokens:\n",
    "    print(t, \": \", ps.stem(t))"
   ]
  }
